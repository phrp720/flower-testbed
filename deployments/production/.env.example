# Database
DATABASE_URL="postgresql://floweruser:flowerpass@postgres:5432/flowertestbed?schema=public"

# Application
NODE_ENV=production

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=q4FbKOLrloRaGo0AL4Xe34Xyb590wVVBi5WOUxFCU28

# Auth Credentials (single user)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin

# Show flower logs in the console
SHOW_FLWR_LOGS=false

# Postgres Settings
POSTGRES_USER=
POSTGRES_PASSWORD=

# Directories to store checkpoints and uploaded data(set absolute paths)
CHECKPOINTS_DIR=
DATA_DIR=

# Experiment execution backend
EXPERIMENT_EXECUTOR=docker

# Optional cap for concurrent worker containers in production Docker mode.
# Leave empty for unlimited.
MAX_CONCURRENT_EXPERIMENTS=

# Container socket settings for worker spawning.
# Standard Docker daemon:
# HOST_CONTAINER_SOCKET_PATH=/var/run/docker.sock
# CONTAINER_SOCKET_PATH=/var/run/docker.sock
#
# Rootless Podman example:
# HOST_CONTAINER_SOCKET_PATH=/run/user/<uid>/podman/podman.sock
# CONTAINER_SOCKET_PATH=/run/podman-user.sock
HOST_CONTAINER_SOCKET_PATH=/var/run/docker.sock
CONTAINER_SOCKET_PATH=/var/run/docker.sock

# Flower/Ray resource tuning
RAY_NUM_CPUS=8
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1

# Image Version
IMAGE_VERSION=latest

VENV_PATH=/opt/venv
